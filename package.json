{
  "name": "clmm",
  "version": "1.0.0",
  "description": "Clean My Mac — Personal CLI tool for macOS system cleanup, app management, and disk optimization",
  "type": "module",
  "bin": {
    "clmm": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsdown src/index.ts --format esm --dts --clean",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "mac",
    "macos",
    "cleaner",
    "cli",
    "disk-space",
    "system-maintenance",
    "app-manager",
    "uninstaller"
  ],
  "author": "brianle",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "10",
    "@types/bun": "^1.2.7",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "10",
    "tsdown": "^0.21.0",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@inquirer/checkbox": "^5.0.2",
    "@inquirer/confirm": "^6.0.2",
    "chalk": "^5.3.0",
    "commander": "^14.0.2",
    "ora": "^9.0.0"
  },
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=20.12.0"
  }
}
